data/raw/
data/processed/
data/bills/pdfs/
data/bills/metadata/
data/companies/
data/market/
data/external/
*.csv
*.parquet
*.xlsx
*.xls
*.db
*.sqlite
*.sqlite3

# But keep the directory structure
!data/.gitkeep
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/bills/.gitkeep
!data/companies/.gitkeep
!data/market/.gitkeep
!data/external/.gitkeep

