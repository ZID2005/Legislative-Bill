# ===========================================================================
# .env.example
# Legislative Intelligence & Market Impact Prediction System
#
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ===========================================================================

# ---------------------------------------------------------------------------
# Runtime environment
# ---------------------------------------------------------------------------
# Options: development | staging | production
ENV=development

# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Project paths
# (Leave blank to use defaults relative to project root)
# ---------------------------------------------------------------------------
# DATA_DIR=data
# RAW_DIR=data/raw
# PROCESSED_DIR=data/processed
# BILLS_DIR=data/bills
# COMPANIES_DIR=data/companies
# MARKET_DIR=data/market
# EXTERNAL_DIR=data/external
# LOGS_DIR=logs
# MODEL_DIR=models/artefacts

# ---------------------------------------------------------------------------
# Data sources — legislative portals
# ---------------------------------------------------------------------------
PRS_BASE_URL=https://prsindia.org
LOK_SABHA_BASE_URL=https://loksabha.nic.in
RAJYA_SABHA_BASE_URL=https://rajyasabha.nic.in

# ---------------------------------------------------------------------------
# HTTP / scraping behaviour
# ---------------------------------------------------------------------------
# Timeout in seconds for each HTTP request
REQUEST_TIMEOUT_SECONDS=30

# Polite delay between successive requests (in seconds, supports decimals)
REQUEST_DELAY_SECONDS=1.5

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# SQLite (default for MVP):
DB_URL=sqlite:///data/legislative_intel.db

# PostgreSQL (production example — do not expose credentials in this file):
# DB_URL=postgresql+psycopg2://user:password@localhost:5432/legislative_intel

# ---------------------------------------------------------------------------
# External API keys
# (Do NOT add real keys here — add them to your private .env file)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key_here
NSE_API_KEY=your_nse_api_key_here
BSE_API_KEY=your_bse_api_key_here

# ---------------------------------------------------------------------------
# Model training
# ---------------------------------------------------------------------------
RANDOM_SEED=42
TEST_SIZE=0.2

# ---------------------------------------------------------------------------
# Future: Cloud storage (Task 9+)
# ---------------------------------------------------------------------------
# AWS_ACCESS_KEY_ID=your_aws_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret
# AWS_DEFAULT_REGION=ap-south-1
# S3_BUCKET_NAME=legislative-intel-data
